{
  "name": "mariusz/slim-ovh-ai",
  "type": "project",
  "require": {
    "php": "^8.4",
    "slim/slim": "^4.15",
    "slim/psr7": "^1.8",
    "php-di/php-di": "^7.0",
    "php-di/slim-bridge": "^3.4",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9",
    "monolog/monolog": "^3.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always"
  }
}