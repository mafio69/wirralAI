# Aplikacja
APP_ENV=dev
APP_DEBUG=true

# Docker / nginx
APP_HOST=localhost
APP_PORT=8080

# SQLite
DB_PATH=/var/www/var/database/app.sqlite

# OVH AI Endpoints
OVH_AI_BASE_URI=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1/
OVH_AI_MODEL=Qwen3-Coder-30B-A3B-Instruct
OVH_AI_ENDPOINTS_ACCESS_TOKEN=your_token_here
OVH_AI_TIMEOUT=60

# Mail (MailPit — dev)
MAIL_DSN=smtp://host.docker.internal:1025
APP_URL=http://localhost:8181

# Logowanie
PASSWORD_HASH_ALGO=sha256
SESSION_EXPIRE_HOURS=24